#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
PROJECT_DIR="${SCRIPT_DIR}"
PROFILES_DIR="${PROJECT_DIR}/../profiles"
PROFILES_LOCAL_DIR="${PROJECT_DIR}/../profiles-local"
RUNTIME_DIR="${PROJECT_DIR}/runtime"
VENV_DIR="${PROJECT_DIR}/.venv"
RENDERER="${PROJECT_DIR}/lib/render_runtime.py"
DEFAULT_MODEL="gpt-5.4"
DEFAULT_MINI_MODEL="gpt-5.4-mini"
DEFAULT_PORT="4000"
LOCAL_NO_PROXY="127.0.0.1,localhost"
EXTRA_ARGS=()
PYTHON_BIN="python3"
if [[ -x "${VENV_DIR}/bin/python" ]]; then
  PYTHON_BIN="${VENV_DIR}/bin/python"
fi

usage() {
  cat <<'EOF'
Usage:
  claude-gateway-switch list
  claude-gateway-switch prepare <profile> [--model MODEL] [--mini-model MODEL] [--port PORT]
  claude-gateway-switch env <profile> [--model MODEL] [--mini-model MODEL] [--port PORT]
  claude-gateway-switch serve <profile> [--model MODEL] [--mini-model MODEL] [--port PORT]
  claude-gateway-switch claude <profile> [--model MODEL] [--mini-model MODEL] [--port PORT] -- [claude args...]
  claude-gateway-switch stop <profile> [--port PORT]
  claude-gateway-switch status
  claude-gateway-switch install
  claude-gateway-switch help
EOF
}

die() {
  echo "$*" >&2
  exit 1
}

require_file() {
  local path="$1"
  [[ -f "${path}" ]] || die "Missing required file: ${path}"
}

require_litellm() {
  [[ -x "${VENV_DIR}/bin/litellm" ]] || die "LiteLLM is not installed. Run: ${PROJECT_DIR}/claude-gateway-switch install"
}

parse_runtime_args() {
  PROFILE=""
  MODEL="${DEFAULT_MODEL}"
  MINI_MODEL="${DEFAULT_MINI_MODEL}"
  PORT="${DEFAULT_PORT}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --model)
        [[ $# -ge 2 ]] || die "Missing value for --model"
        MODEL="$2"
        shift 2
        ;;
      --mini-model)
        [[ $# -ge 2 ]] || die "Missing value for --mini-model"
        MINI_MODEL="$2"
        shift 2
        ;;
      --port)
        [[ $# -ge 2 ]] || die "Missing value for --port"
        PORT="$2"
        shift 2
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "Unknown option: $1"
        ;;
      *)
        if [[ -z "${PROFILE}" ]]; then
          PROFILE="$1"
          shift
        else
          break
        fi
        ;;
    esac
  done

  EXTRA_ARGS=("$@")
  [[ -n "${PROFILE}" ]] || die "Missing profile name"
}

pid_file_path() {
  local profile="$1"
  local port="$2"
  echo "${RUNTIME_DIR}/litellm-${profile}-${port}.pid"
}

log_file_path() {
  local profile="$1"
  local port="$2"
  echo "${RUNTIME_DIR}/litellm-${profile}-${port}.log"
}

prepare_runtime() {
  local profile="$1"
  local model="$2"
  local mini_model="$3"
  local port="$4"

  mkdir -p "${RUNTIME_DIR}"
  "${PYTHON_BIN}" "${RENDERER}" render \
    --profiles-root "${PROFILES_DIR}" \
    --profiles-local-root "${PROFILES_LOCAL_DIR}" \
    --runtime-root "${RUNTIME_DIR}" \
    --profile "${profile}" \
    --model "${model}" \
    --mini-model "${mini_model}" \
    --port "${port}"
}

list_profiles() {
  "${PYTHON_BIN}" "${RENDERER}" list \
    --profiles-root "${PROFILES_DIR}" \
    --profiles-local-root "${PROFILES_LOCAL_DIR}"
}

prepare_command() {
  parse_runtime_args "$@"
  prepare_runtime "${PROFILE}" "${MODEL}" "${MINI_MODEL}" "${PORT}"
}

env_command() {
  parse_runtime_args "$@"
  prepare_runtime "${PROFILE}" "${MODEL}" "${MINI_MODEL}" "${PORT}" >/dev/null
  local env_path="${RUNTIME_DIR}/${PROFILE}.claude.env"
  require_file "${env_path}"
  sed -n '1,200p' "${env_path}"
}

wait_for_port() {
  local port="$1"
  "${PYTHON_BIN}" - "$port" <<'PY'
import socket
import sys
import time

port = int(sys.argv[1])
deadline = time.time() + 12
while time.time() < deadline:
    try:
        with socket.socket() as sock:
            sock.settimeout(0.5)
            sock.connect(("127.0.0.1", port))
    except PermissionError:
        sys.exit(2)
    except OSError:
        time.sleep(0.3)
        continue
    sys.exit(0)
sys.exit(1)
PY
}

is_port_open() {
  local port="$1"
  "${PYTHON_BIN}" - "$port" <<'PY'
import socket
import sys

port = int(sys.argv[1])
try:
    with socket.socket() as sock:
        sock.settimeout(0.5)
        sock.connect(("127.0.0.1", port))
except PermissionError:
    sys.exit(2)
except OSError:
    sys.exit(1)
sys.exit(0)
PY
}

healthcheck_ok() {
  local port="$1"
  NO_PROXY="${LOCAL_NO_PROXY}${NO_PROXY:+,${NO_PROXY}}" \
    no_proxy="${LOCAL_NO_PROXY}${no_proxy:+,${no_proxy}}" \
    curl --noproxy '*' -fsS "http://127.0.0.1:${port}/health/liveliness" >/dev/null 2>&1
}

serve_command() {
  parse_runtime_args "$@"
  require_litellm
  prepare_runtime "${PROFILE}" "${MODEL}" "${MINI_MODEL}" "${PORT}" >/dev/null

  local pid_file
  local log_file
  local config_path
  local env_path

  pid_file="$(pid_file_path "${PROFILE}" "${PORT}")"
  log_file="$(log_file_path "${PROFILE}" "${PORT}")"
  config_path="${RUNTIME_DIR}/${PROFILE}.yaml"
  env_path="${RUNTIME_DIR}/${PROFILE}.litellm.env"

  require_file "${config_path}"
  require_file "${env_path}"

  if is_port_open "${PORT}"; then
    echo "LiteLLM already listening on port ${PORT}"
    return 0
  fi

  if [[ -f "${pid_file}" ]]; then
    local pid
    pid="$(cat "${pid_file}")"
    if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
      echo "LiteLLM already running for ${PROFILE} on port ${PORT} (pid ${pid})"
      return 0
    fi
    rm -f "${pid_file}"
  fi

  set -a
  source "${env_path}"
  set +a

  "${PYTHON_BIN}" - "${VENV_DIR}/bin/litellm" "${config_path}" "${PORT}" "${log_file}" "${pid_file}" <<'PY'
import subprocess
import sys
from pathlib import Path

command, config_path, port, log_path, pid_path = sys.argv[1:]
log_file = Path(log_path)
pid_file = Path(pid_path)

with log_file.open("ab") as log_handle:
    proc = subprocess.Popen(
        [command, "--config", config_path, "--port", port],
        stdin=subprocess.DEVNULL,
        stdout=log_handle,
        stderr=log_handle,
        start_new_session=True,
    )

pid_file.write_text(f"{proc.pid}\n", encoding="utf-8")
PY
  chmod 600 "${pid_file}" "${log_file}" 2>/dev/null || true

  if ! wait_for_port "${PORT}" && ! healthcheck_ok "${PORT}"; then
    echo "LiteLLM failed to start. Recent log output:" >&2
    sed -n '1,200p' "${log_file}" >&2 || true
    exit 1
  fi

  echo "LiteLLM started for ${PROFILE} on http://127.0.0.1:${PORT}"
  echo "Log: ${log_file}"
}

claude_command() {
  parse_runtime_args "$@"
  prepare_runtime "${PROFILE}" "${MODEL}" "${MINI_MODEL}" "${PORT}" >/dev/null

  local env_path
  local settings_path
  env_path="${RUNTIME_DIR}/${PROFILE}.claude.env"
  settings_path="${RUNTIME_DIR}/${PROFILE}.claude.settings.json"
  require_file "${env_path}"
  require_file "${settings_path}"

  local pid_file
  pid_file="$(pid_file_path "${PROFILE}" "${PORT}")"
  if is_port_open "${PORT}"; then
    :
  elif [[ -f "${pid_file}" ]]; then
    local pid
    pid="$(cat "${pid_file}")"
    if [[ -n "${pid}" ]] && ! kill -0 "${pid}" 2>/dev/null; then
      die "Gateway pid file exists but process is not running. Start it with: ${PROJECT_DIR}/claude-gateway-switch serve ${PROFILE}"
    fi
  else
    die "Gateway is not running. Start it with: ${PROJECT_DIR}/claude-gateway-switch serve ${PROFILE}"
  fi

  set -a
  source "${env_path}"
  set +a

  if (( ${#EXTRA_ARGS[@]} )); then
    exec claude --settings "${settings_path}" "${EXTRA_ARGS[@]}"
  fi
  exec claude --settings "${settings_path}"
}

stop_command() {
  parse_runtime_args "$@"
  local pid_file
  pid_file="$(pid_file_path "${PROFILE}" "${PORT}")"

  if is_port_open "${PORT}" && [[ ! -f "${pid_file}" ]]; then
    die "Port ${PORT} is in use but no pid file is available. Stop the process manually."
  fi
  [[ -f "${pid_file}" ]] || die "No pid file found for ${PROFILE} on port ${PORT}"

  local pid
  pid="$(cat "${pid_file}")"
  if [[ -z "${pid}" ]]; then
    rm -f "${pid_file}"
    die "Invalid pid file: ${pid_file}"
  fi

  if kill -0 "${pid}" 2>/dev/null; then
    kill "${pid}"
    echo "Stopped LiteLLM for ${PROFILE} (pid ${pid})"
  else
    echo "Process ${pid} is not running; removing stale pid file"
  fi
  rm -f "${pid_file}"
}

status_command() {
  mkdir -p "${RUNTIME_DIR}"
  local found=0
  local pid_file
  for pid_file in "${RUNTIME_DIR}"/litellm-*.pid; do
    [[ -f "${pid_file}" ]] || continue
    found=1
    local pid
    pid="$(cat "${pid_file}")"
    local name
    name="$(basename "${pid_file}" .pid)"
    local port
    port="${name##*-}"
    if is_port_open "${port}"; then
      echo "${name}: listening on port ${port}"
    elif [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
      echo "${name}: running (pid ${pid})"
    else
      echo "${name}: stale pid file"
    fi
  done

  if [[ "${found}" -eq 0 ]]; then
    echo "No LiteLLM gateway pid files found in ${RUNTIME_DIR}"
  fi
}

install_command() {
  python3 -m venv "${VENV_DIR}"
  PIP_DISABLE_PIP_VERSION_CHECK=1 "${VENV_DIR}/bin/pip" install --upgrade pip
  PIP_DISABLE_PIP_VERSION_CHECK=1 "${VENV_DIR}/bin/pip" install "litellm[proxy]!=1.82.7,!=1.82.8" toml tomli
}

main() {
  require_file "${RENDERER}"

  local command="${1:-help}"
  shift || true

  case "${command}" in
    list)
      list_profiles
      ;;
    prepare)
      prepare_command "$@"
      ;;
    env)
      env_command "$@"
      ;;
    serve)
      serve_command "$@"
      ;;
    claude)
      claude_command "$@"
      ;;
    stop)
      stop_command "$@"
      ;;
    status)
      status_command
      ;;
    install)
      install_command
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      usage
      exit 1
      ;;
  esac
}

main "$@"
