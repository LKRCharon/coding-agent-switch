#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BIN_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
PROJECT_ROOT="$(cd "${BIN_DIR}/.." && pwd)"
GATEWAY_DIR="${PROJECT_ROOT}/gateway"
CLAUDE_GATEWAY_SWITCH="${GATEWAY_DIR}/claude-gateway-switch"
PROFILES_ROOT="${PROJECT_ROOT}/profiles"
PROFILES_LOCAL_ROOT="${PROFILES_LOCAL_ROOT:-${PROJECT_ROOT}/profiles-local}"
BALANCE_HELPER="${PROJECT_ROOT}/lib/provider_balance.py"
ROOT_ENV_FILE="${ROOT_ENV_FILE:-${PROJECT_ROOT}/.env}"
SUB2API_CTL="${SUB2API_CTL:-${PROJECT_ROOT}/sub2api-local/sub2api-localctl}"
ADD_PROFILE_SCRIPT="${PROJECT_ROOT}/bin/add-profile"
LOCAL_NO_PROXY="127.0.0.1,localhost"
PYTHON_BIN="${GATEWAY_DIR}/.venv/bin/python"
if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="python3"
fi

export NO_PROXY="$LOCAL_NO_PROXY${NO_PROXY:+,$NO_PROXY}"
export no_proxy="$LOCAL_NO_PROXY${no_proxy:+,$no_proxy}"

load_local_env_file() {
  local env_file="$1"
  [[ -f "${env_file}" ]] || return 0
  set -a
  # shellcheck disable=SC1090
  source "${env_file}"
  set +a
}

load_local_env_file "${ROOT_ENV_FILE}"

usage() {
  cat <<'USAGE'
Usage:
  agent-switch                          # interactive menu (numbers or arrow keys)
  agent-switch [claude|codex] [profile] [serve|stop|status|logs|env|show|prepare|backend] [extra args...]
  agent-switch codex [profile] use
  agent-switch codex [profile] run [codex args...]
  agent-switch codex [profile] logout
  agent-switch codex native export-auth <name>
  agent-switch codex native restore-auth <name>
  agent-switch [claude|codex] [profile] [client args...]
  agent-switch balance <provider> [--token TOKEN | --username USER --prompt-password] [--days 30] [--json]
  agent-switch balance-login <provider> [--username USER --prompt-password]
  agent-switch profile list
  agent-switch profile add [--name NAME] [--base-url URL] [--api-key KEY] [--provider-snippet-file PATH|-]
  agent-switch profile create <name> --base-url URL [--env-key KEY] [--api-key KEY] [--model MODEL] [--reasoning LEVEL]
  agent-switch list

Profiles:
  native   -> claude/codex native mode (no gateway)
  provider -> default port 4030 (generic provider endpoint)
  local profiles can be stored under profiles-local/ (ignored by git)

Examples:
  agent-switch list
  agent-switch codex ttapi
  agent-switch codex ttapi use
  agent-switch codex ttapi run -p "Reply with exactly OK."
  agent-switch codex logout
  agent-switch codex native export-auth official-main
  agent-switch codex native restore-auth official-main
  agent-switch claude native
  agent-switch claude provider -p "Reply with exactly OK."
  agent-switch profile create ttapi --base-url https://api.example.com/v1 --env-key TTAPI_API_KEY --api-key ...
  agent-switch balance provider --json
  agent-switch balance-login provider --username your_name --prompt-password
USAGE
}

clear_screen() {
  printf '\033[2J\033[H'
}

pause_for_menu() {
  if [[ -t 0 ]]; then
    printf '\nPress Enter to continue...'
    IFS= read -r _ || true
  fi
}

menu_pick() {
  local title="$1"
  shift
  local -a options=("$@")
  local selected=0
  local key=""
  local next=""

  [[ ${#options[@]} -gt 0 ]] || die "menu_pick requires at least one option"

  while true; do
    clear_screen
    echo "${title}"
    echo
    echo "Use number or ↑/↓ then Enter. Press q to quit."
    echo
    local i=0
    for i in "${!options[@]}"; do
      local item_no=$((i + 1))
      if [[ "${i}" -eq "${selected}" ]]; then
        printf '  > %2d) %s\n' "${item_no}" "${options[$i]}"
      else
        printf '    %2d) %s\n' "${item_no}" "${options[$i]}"
      fi
    done

    IFS= read -rsn1 key || return 1
    case "${key}" in
      "")
        MENU_INDEX="${selected}"
        return 0
        ;;
      [0-9])
        local number_text="${key}"
        if (( ${#options[@]} > 9 )); then
          printf '\nType full number then Enter [%s]: ' "${key}"
          IFS= read -r next || true
          next="${next//[^0-9]/}"
          number_text+="${next}"
        fi
        local picked
        picked=$((10#${number_text}))
        if (( picked >= 1 && picked <= ${#options[@]} )); then
          MENU_INDEX=$((picked - 1))
          return 0
        fi
        ;;
      q|Q)
        return 1
        ;;
      $'\x1b')
        if IFS= read -rsn1 -t 1 next && [[ "${next}" == "[" ]]; then
          if IFS= read -rsn1 -t 1 next; then
            case "${next}" in
              A)
                selected=$(( (selected - 1 + ${#options[@]}) % ${#options[@]} ))
                ;;
              B)
                selected=$(( (selected + 1) % ${#options[@]} ))
                ;;
            esac
          fi
        fi
        ;;
    esac
  done
}

build_action_options() {
  local client="$1"
  local profile="$2"
  ACTION_LABELS=()
  ACTION_VALUES=()

  if [[ "${client}" == "codex" ]]; then
    if [[ "${profile}" == "native" ]]; then
      ACTION_LABELS+=("Start codex (native)")
      ACTION_VALUES+=("run")
      ACTION_LABELS+=("Show status")
      ACTION_VALUES+=("status")
      ACTION_LABELS+=("Show env")
      ACTION_VALUES+=("env")
    else
      ACTION_LABELS+=("Use profile (persist to ~/.codex)")
      ACTION_VALUES+=("use")
      ACTION_LABELS+=("Show profile summary")
      ACTION_VALUES+=("show")
      ACTION_LABELS+=("Run codex once with profile")
      ACTION_VALUES+=("run")
      ACTION_LABELS+=("Show status")
      ACTION_VALUES+=("status")
      ACTION_LABELS+=("Show env")
      ACTION_VALUES+=("env")
    fi
  else
    ACTION_LABELS+=("Start ${client} (interactive)")
    ACTION_VALUES+=("run")
    ACTION_LABELS+=("Show status")
    ACTION_VALUES+=("status")
    ACTION_LABELS+=("Show env")
    ACTION_VALUES+=("env")
    if [[ "${profile}" != "native" ]]; then
      ACTION_LABELS+=("Prepare gateway profile")
      ACTION_VALUES+=("prepare")
      ACTION_LABELS+=("Start gateway")
      ACTION_VALUES+=("serve")
      ACTION_LABELS+=("Stop gateway")
      ACTION_VALUES+=("stop")
      if [[ "${profile}" == "sub2api" ]]; then
        ACTION_LABELS+=("Show backend logs")
        ACTION_VALUES+=("logs")
      fi
    fi
  fi

  ACTION_LABELS+=("Back")
  ACTION_VALUES+=("back")
  ACTION_LABELS+=("Exit")
  ACTION_VALUES+=("exit")
}

run_client_action() {
  local client="$1"
  local action="$2"
  if [[ "${client}" == "claude" ]]; then
    case "${action}" in
      run) run_claude ;;
      *) run_claude "${action}" ;;
    esac
  else
    case "${action}" in
      run) run_codex run ;;
      *) run_codex "${action}" ;;
    esac
  fi
}

run_interactive_menu() {
  local selected_client=""
  local selected_profile=""

  while true; do
    local -a client_labels=("Claude" "Codex" "Exit")
    local -a client_values=("claude" "codex" "exit")
    menu_pick "Agent Switch" "${client_labels[@]}" || return 0
    selected_client="${client_values[$MENU_INDEX]}"
    if [[ "${selected_client}" == "exit" ]]; then
      return 0
    fi

    while true; do
      local -a profiles=()
      local profile_name=""
      while IFS= read -r profile_name; do
        [[ -n "${profile_name}" ]] || continue
        profiles+=("${profile_name}")
      done < <(list_profiles)
      profiles+=("Back" "Exit")

      menu_pick "Select profile for ${selected_client}" "${profiles[@]}" || return 0
      selected_profile="${profiles[$MENU_INDEX]}"

      if [[ "${selected_profile}" == "Back" ]]; then
        break
      fi
      if [[ "${selected_profile}" == "Exit" ]]; then
        return 0
      fi

      PROFILE="${selected_profile}"
      PROFILE_EXPLICIT=1
      PORT="$(port_for_profile "${PROFILE}")"
      CLIENT="${selected_client}"

      while true; do
        build_action_options "${selected_client}" "${selected_profile}"
        menu_pick "Select action (${selected_client} / ${selected_profile})" "${ACTION_LABELS[@]}" || return 0
        local action="${ACTION_VALUES[$MENU_INDEX]}"

        if [[ "${action}" == "back" ]]; then
          break
        fi
        if [[ "${action}" == "exit" ]]; then
          return 0
        fi

        clear_screen
        echo "Running: agent-switch ${selected_client} ${selected_profile} ${action}"
        echo
        run_client_action "${selected_client}" "${action}"
        pause_for_menu
      done
    done
  done
}

die() {
  echo "$*" >&2
  exit 1
}

require_explicit_profile() {
  local action="$1"
  [[ "${PROFILE_EXPLICIT}" == "1" ]] || die "${action} requires an explicit profile"
}

is_client() {
  case "$1" in
    claude|codex) return 0 ;;
    *) return 1 ;;
  esac
}

is_claude_command() {
  case "$1" in
    ""|help|-h|--help|list|backend|serve|stop|status|logs|env|prepare) return 0 ;;
    *) return 1 ;;
  esac
}

is_codex_command() {
  case "$1" in
    ""|help|-h|--help|list|use|run|backend|serve|stop|status|logs|env|persist|show|prepare|logout) return 0 ;;
    *) return 1 ;;
  esac
}

is_profile() {
  [[ "$1" == "native" ]] && return 0
  [[ -n "$(resolve_profile_dir "$1")" ]]
}

is_runnable_profile_dir() {
  local dir="$1"
  [[ -d "${dir}" && -f "${dir}/config.toml" ]]
}

resolve_profile_dir() {
  local profile="$1"
  if is_runnable_profile_dir "${PROFILES_LOCAL_ROOT}/${profile}"; then
    echo "${PROFILES_LOCAL_ROOT}/${profile}"
    return 0
  fi
  if is_runnable_profile_dir "${PROFILES_ROOT}/${profile}"; then
    echo "${PROFILES_ROOT}/${profile}"
    return 0
  fi
  return 1
}

list_profiles() {
  echo "native"
  {
    if [[ -d "${PROFILES_ROOT}" ]]; then
      find "${PROFILES_ROOT}" -mindepth 1 -maxdepth 1 -type d -name '*' \
        -exec test -f "{}/config.toml" \; -exec basename {} \;
    fi
    if [[ -d "${PROFILES_LOCAL_ROOT}" ]]; then
      find "${PROFILES_LOCAL_ROOT}" -mindepth 1 -maxdepth 1 -type d -name '*' \
        -exec test -f "{}/config.toml" \; -exec basename {} \;
    fi
  } | sort -u
}

default_profile() {
  local first
  first="$({
    if [[ -d "${PROFILES_ROOT}" ]]; then
      find "${PROFILES_ROOT}" -mindepth 1 -maxdepth 1 -type d -name '*' \
        -exec test -f "{}/config.toml" \; -exec basename {} \;
    fi
    if [[ -d "${PROFILES_LOCAL_ROOT}" ]]; then
      find "${PROFILES_LOCAL_ROOT}" -mindepth 1 -maxdepth 1 -type d -name '*' \
        -exec test -f "{}/config.toml" \; -exec basename {} \;
    fi
  } | sort -u | head -n 1)"
  if [[ -n "${first}" ]]; then
    echo "${first}"
    return
  fi

  echo "native"
}

port_for_profile() {
  case "$1" in
    provider) echo "4030" ;;
    *) echo "4040" ;;
  esac
}

run_backend() {
  [[ -x "${SUB2API_CTL}" ]] || die "sub2api backend controller not found: ${SUB2API_CTL}"
  "${SUB2API_CTL}" "$@"
}

ensure_backend_started() {
  if [[ "${PROFILE}" == "sub2api" ]]; then
    run_backend start
  fi
}

stop_backend_if_needed() {
  if [[ "${PROFILE}" == "sub2api" ]]; then
    run_backend stop
  fi
}

json_quote() {
  "${PYTHON_BIN}" -c 'import json,sys; print(json.dumps(sys.argv[1], ensure_ascii=True))' "$1"
}

load_profile_vars() {
  local profile_dir
  local rendered
  profile_dir="$(resolve_profile_dir "${PROFILE}")" || die "unknown profile: ${PROFILE}"

  if ! rendered="$("${PYTHON_BIN}" - "$profile_dir" "$PROFILE" <<'PY'
import json
import os
import shlex
import sys
try:
    import tomllib
except ModuleNotFoundError:
    import tomli as tomllib
from pathlib import Path

profile_dir = Path(sys.argv[1])
profile = sys.argv[2]
cfg_path = profile_dir / "config.toml"
auth_path = profile_dir / "auth.json"

if not cfg_path.is_file():
    raise SystemExit(f"missing profile config: {cfg_path}")

cfg = tomllib.loads(cfg_path.read_text(encoding="utf-8"))
providers = cfg.get("model_providers", {})
provider = providers.get(profile)
if provider is None:
    raise SystemExit(f"profile provider section missing: model_providers.{profile}")

auth = {}
if auth_path.is_file():
    auth = json.loads(auth_path.read_text(encoding="utf-8"))

env_key = str(provider.get("env_key", "OPENAI_API_KEY"))
api_key = str(auth.get("OPENAI_API_KEY", "")).strip() or str(os.getenv(env_key, "")).strip() or str(os.getenv("OPENAI_API_KEY", "")).strip()

model = str(cfg.get("model", "gpt-5.4"))
reasoning = str(cfg.get("model_reasoning_effort", ""))
base_url = str(provider.get("base_url", ""))
provider_name = str(provider.get("name", profile))
wire_api = str(provider.get("wire_api", "responses"))
requires_auth = bool(provider.get("requires_openai_auth", True))


def emit(k: str, v: str) -> None:
    print(f"{k}={shlex.quote(v)}")

emit("PROFILE_MODEL", model)
emit("PROFILE_REASONING", reasoning)
emit("PROFILE_API_KEY", api_key)
emit("PROFILE_BASE_URL", base_url)
emit("PROFILE_PROVIDER_NAME", provider_name)
emit("PROFILE_WIRE_API", wire_api)
emit("PROFILE_ENV_KEY", env_key)
emit("PROFILE_REQUIRES_OPENAI_AUTH", "true" if requires_auth else "false")
PY
  )"; then
    die "failed to load profile: ${PROFILE}"
  fi

  eval "${rendered}"
}

persist_codex_profile() {
  [[ "${PROFILE}" != "native" ]] || die "persist does not apply to native"
  load_profile_vars
  [[ -n "${PROFILE_API_KEY}" ]] || die "No API key found for ${PROFILE}. Put it in ${ROOT_ENV_FILE} (key: ${PROFILE_ENV_KEY}) or profiles-local/${PROFILE}/auth.json"

  local codex_home
  local config_path
  local auth_path
  codex_home="${CODEX_HOME:-${HOME}/.codex}"
  config_path="${codex_home}/config.toml"
  auth_path="${codex_home}/auth.json"

  "${PYTHON_BIN}" - "$config_path" "$auth_path" "$PROFILE" "$PROFILE_MODEL" "$PROFILE_REASONING" "$PROFILE_PROVIDER_NAME" "$PROFILE_BASE_URL" "$PROFILE_WIRE_API" "$PROFILE_REQUIRES_OPENAI_AUTH" "$PROFILE_ENV_KEY" "$PROFILE_API_KEY" <<'PY'
from __future__ import annotations
import json
import re
import shutil
import sys
from datetime import datetime
from pathlib import Path

config_path = Path(sys.argv[1])
auth_path = Path(sys.argv[2])
profile = sys.argv[3]
model = sys.argv[4]
reasoning = sys.argv[5]
provider_name = sys.argv[6]
base_url = sys.argv[7]
wire_api = sys.argv[8]
requires_auth = sys.argv[9].lower() == "true"
env_key = sys.argv[10]
api_key = sys.argv[11]

config_path.parent.mkdir(parents=True, exist_ok=True)
auth_path.parent.mkdir(parents=True, exist_ok=True)

ts = datetime.now().strftime("%Y%m%d-%H%M%S")

config_text = ""
if config_path.exists() and config_path.stat().st_size > 0:
    config_text = config_path.read_text(encoding="utf-8")
    shutil.copy2(config_path, config_path.with_name(f"{config_path.name}.bak.{ts}"))
top_level_lines = []
top_level_lines.append(f'model_provider = "{profile}"')
if model:
    top_level_lines.append(f'model = "{model}"')
if reasoning:
    top_level_lines.append(f'model_reasoning_effort = "{reasoning}"')

for line in top_level_lines:
    key = line.split("=", 1)[0].strip()
    pattern = re.compile(rf"(?m)^\s*{re.escape(key)}\s*=.*(?:\n|$)")
    replacement = line + "\n"
    if pattern.search(config_text):
        config_text = pattern.sub(replacement, config_text, count=1)
    else:
        config_text = replacement + config_text

table_header = f"[model_providers.{profile}]"
table_body = [
    f'name = "{provider_name or profile}"\n',
    f'base_url = "{base_url}"\n',
    f'wire_api = "{wire_api or "responses"}"\n',
    f'requires_openai_auth = {"true" if requires_auth else "false"}\n',
    f'env_key = "{env_key}"\n',
]

lines = config_text.splitlines(keepends=True)
out_lines: list[str] = []
i = 0
replaced = False
target_header = table_header.strip()
while i < len(lines):
    if lines[i].strip() != target_header:
        out_lines.append(lines[i])
        i += 1
        continue

    replaced = True
    out_lines.append(table_header + "\n")
    out_lines.extend(table_body)
    i += 1
    while i < len(lines) and not re.match(r"^\s*\[", lines[i]):
        i += 1
    if i < len(lines) and out_lines and out_lines[-1].strip():
        out_lines.append("\n")

if not replaced:
    if out_lines and out_lines[-1].strip():
        out_lines.append("\n")
    out_lines.append(table_header + "\n")
    out_lines.extend(table_body)

config_text = "".join(out_lines)
config_text = re.sub(r"\n{3,}", "\n\n", config_text).lstrip("\n")
if config_text and not config_text.endswith("\n"):
    config_text += "\n"

config_path.write_text(config_text, encoding="utf-8")

auth: dict = {}
if auth_path.exists() and auth_path.stat().st_size > 0:
    auth = json.loads(auth_path.read_text(encoding="utf-8"))
    shutil.copy2(auth_path, auth_path.with_name(f"{auth_path.name}.bak.{ts}"))
auth["OPENAI_API_KEY"] = api_key
auth_path.write_text(json.dumps(auth, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY

  echo "Persisted codex profile=${PROFILE} to ${config_path} (provider key: ${PROFILE})"
  echo "Updated ${auth_path} OPENAI_API_KEY to active profile key"
}

validate_snapshot_name() {
  local name="$1"
  [[ -n "${name}" ]] || die "snapshot name is required"
  [[ "${name}" =~ ^[a-z0-9][a-z0-9-]*$ ]] || die "snapshot name must match: [a-z0-9][a-z0-9-]*"
}

snapshot_dir_for_name() {
  local name="$1"
  echo "${PROFILES_LOCAL_ROOT}/${name}/codex-native"
}

export_codex_native_auth() {
  local name="${1:-}"
  validate_snapshot_name "${name}"

  local codex_home="${CODEX_HOME:-${HOME}/.codex}"
  local auth_path="${codex_home}/auth.json"
  local config_path="${codex_home}/config.toml"
  local snapshot_dir
  snapshot_dir="$(snapshot_dir_for_name "${name}")"

  [[ -f "${auth_path}" ]] || die "missing ${auth_path}; nothing to export"
  [[ -f "${config_path}" ]] || die "missing ${config_path}; nothing to export"

  mkdir -p "${snapshot_dir}"
  "${PYTHON_BIN}" - "${auth_path}" "${config_path}" "${snapshot_dir}" <<'PY'
from __future__ import annotations
import shutil
import sys
from datetime import datetime
from pathlib import Path

auth_path = Path(sys.argv[1])
config_path = Path(sys.argv[2])
snapshot_dir = Path(sys.argv[3])
snapshot_dir.mkdir(parents=True, exist_ok=True)

ts = datetime.now().strftime("%Y%m%d-%H%M%S")
for filename in ("auth.json", "config.toml"):
    target = snapshot_dir / filename
    if target.exists():
        shutil.copy2(target, snapshot_dir / f"{filename}.bak.{ts}")

shutil.copy2(auth_path, snapshot_dir / "auth.json")
shutil.copy2(config_path, snapshot_dir / "config.toml")
for target in (snapshot_dir / "auth.json", snapshot_dir / "config.toml"):
    target.chmod(0o600)
PY

  echo "Exported ~/.codex auth snapshot to ${snapshot_dir}"
}

restore_codex_native_auth() {
  local name="${1:-}"
  validate_snapshot_name "${name}"

  local snapshot_dir
  snapshot_dir="$(snapshot_dir_for_name "${name}")"
  local snapshot_auth="${snapshot_dir}/auth.json"
  local snapshot_config="${snapshot_dir}/config.toml"
  [[ -f "${snapshot_auth}" ]] || die "missing ${snapshot_auth}; run export-auth first"
  [[ -f "${snapshot_config}" ]] || die "missing ${snapshot_config}; run export-auth first"

  local codex_home="${CODEX_HOME:-${HOME}/.codex}"
  local auth_path="${codex_home}/auth.json"
  local config_path="${codex_home}/config.toml"

  mkdir -p "${codex_home}"
  "${PYTHON_BIN}" - "${snapshot_auth}" "${snapshot_config}" "${auth_path}" "${config_path}" <<'PY'
from __future__ import annotations
import shutil
import sys
from datetime import datetime
from pathlib import Path

snapshot_auth = Path(sys.argv[1])
snapshot_config = Path(sys.argv[2])
auth_path = Path(sys.argv[3])
config_path = Path(sys.argv[4])

ts = datetime.now().strftime("%Y%m%d-%H%M%S")
for target in (auth_path, config_path):
    if target.exists():
        shutil.copy2(target, target.with_name(f"{target.name}.bak.{ts}"))

shutil.copy2(snapshot_auth, auth_path)
shutil.copy2(snapshot_config, config_path)
for target in (auth_path, config_path):
    target.chmod(0o600)
PY

  echo "Restored ~/.codex auth snapshot from ${snapshot_dir}"
}

logout_codex() {
  local codex_home
  local config_path
  local rc=0
  codex_home="${CODEX_HOME:-${HOME}/.codex}"
  config_path="${codex_home}/config.toml"

  cleanup_codex_provider_config() {
    "${PYTHON_BIN}" - "$config_path" <<'PY'
from __future__ import annotations
import re
import shutil
import sys
from datetime import datetime
from pathlib import Path

config_path = Path(sys.argv[1])
if not config_path.exists() or config_path.stat().st_size == 0:
    raise SystemExit(0)

text = config_path.read_text(encoding="utf-8")
changed = False
active_provider = None

model_provider_re = re.compile(r'^\s*model_provider\s*=\s*"([^"]+)"\s*$', re.MULTILINE)
model_provider_match = model_provider_re.search(text)
if model_provider_match:
    active_provider = model_provider_match.group(1).strip()
    text = model_provider_re.sub("", text)
    changed = True

lines = text.splitlines(keepends=True)
out_lines: list[str] = []
section_re = re.compile(r'^\s*\[model_providers\.([^\]]+)\]\s*$')
base_url_re = re.compile(r'^\s*base_url\s*=\s*"([^"]*)"\s*$')
i = 0
while i < len(lines):
    header_match = section_re.match(lines[i])
    if not header_match:
        out_lines.append(lines[i])
        i += 1
        continue

    section_name = header_match.group(1).strip()
    j = i + 1
    section_body: list[str] = []
    while j < len(lines):
        if re.match(r'^\s*\[', lines[j]):
            break
        section_body.append(lines[j])
        j += 1

    should_drop = False
    if section_name == "agent_switch":
        should_drop = True
    elif active_provider and section_name == active_provider:
        for section_line in section_body:
            base_url_match = base_url_re.match(section_line)
            if base_url_match and base_url_match.group(1).strip():
                should_drop = True
                break

    if should_drop:
        changed = True
    else:
        out_lines.append(lines[i])
        out_lines.extend(section_body)
    i = j

text = "".join(out_lines)

if changed:
    # Clean up excessive blank lines introduced by block removals.
    text = re.sub(r"\n{3,}", "\n\n", text).lstrip("\n")
    if text and not text.endswith("\n"):
        text += "\n"

if not changed:
    raise SystemExit(0)

if re.search(r"^\s*\[model_providers\.", text, re.MULTILINE) is None:
    # Remove map-style section assignment leftovers if no provider tables remain.
    map_style_re = re.compile(r"^\s*model_providers\s*=\s*\{\s*\}\s*$", re.MULTILINE)
    if map_style_re.search(text):
        text = map_style_re.sub("", text)
        text = re.sub(r"\n{3,}", "\n\n", text).lstrip("\n")
        if text and not text.endswith("\n"):
            text += "\n"
        changed = True

if not changed:
    raise SystemExit(0)

ts = datetime.now().strftime("%Y%m%d-%H%M%S")
shutil.copy2(config_path, config_path.with_name(f"{config_path.name}.bak.{ts}"))
config_path.write_text(text, encoding="utf-8")
print(f"Cleaned codex provider residue in {config_path}")
PY
  }

  if ! cleanup_codex_provider_config; then
    echo "Warning: failed to clean ${config_path} before codex logout" >&2
  fi

  if ! codex logout "$@"; then
    rc=$?
  fi

  if ! cleanup_codex_provider_config; then
    echo "Warning: failed to clean ${config_path} after codex logout" >&2
  fi

  return "$rc"
}

run_profile() {
  local sub="${1:-}"
  case "$sub" in
    ""|help|-h|--help)
      cat <<'USAGE'
Usage:
  agent-switch profile list
  agent-switch profile add [--name NAME] [--base-url URL] [--api-key KEY] [--provider-snippet-file PATH|-]
  agent-switch profile create <name> --base-url URL [--env-key KEY] [--api-key KEY] [--model MODEL] [--reasoning LEVEL]
USAGE
      ;;
    list)
      list_profiles
      ;;
    add)
      shift || true
      [[ -x "${ADD_PROFILE_SCRIPT}" ]] || die "missing add-profile script: ${ADD_PROFILE_SCRIPT}"
      "${ADD_PROFILE_SCRIPT}" "$@"
      ;;
    create)
      shift || true
      local name="${1:-}"
      [[ -n "${name}" ]] || die "Usage: agent-switch profile create <name> --base-url URL [--env-key KEY] [--api-key KEY] [--model MODEL] [--reasoning LEVEL]"
      shift || true
      [[ -x "${ADD_PROFILE_SCRIPT}" ]] || die "missing add-profile script: ${ADD_PROFILE_SCRIPT}"
      "${ADD_PROFILE_SCRIPT}" --non-interactive --name "${name}" "$@"
      ;;
    *)
      die "unknown profile subcommand: ${sub}"
      ;;
  esac
}

run_balance() {
  [[ -f "${BALANCE_HELPER}" ]] || die "Missing helper: ${BALANCE_HELPER}"
  exec "${PYTHON_BIN}" "${BALANCE_HELPER}" "$@"
}

token_env_key_for_provider() {
  case "$1" in
    provider) echo "PROVIDER_AUTH_TOKEN" ;;
    *) echo "${1^^}_AUTH_TOKEN" ;;
  esac
}

upsert_env_var() {
  local env_file="$1"
  local key="$2"
  local value="$3"
  "${PYTHON_BIN}" - "$env_file" "$key" "$value" <<'PY'
from pathlib import Path
import sys

env_path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]

line = f"{key}='{value.replace("'", "'\"'\"'")}'"

lines = []
if env_path.exists():
    lines = env_path.read_text(encoding="utf-8").splitlines()

updated = False
new_lines = []
for raw in lines:
    stripped = raw.strip()
    if stripped.startswith(f"{key}="):
        if not updated:
            new_lines.append(line)
            updated = True
        continue
    new_lines.append(raw)

if not updated:
    if new_lines and new_lines[-1] != "":
        new_lines.append("")
    new_lines.append(line)

env_path.write_text("\n".join(new_lines) + "\n", encoding="utf-8")
PY
  chmod 600 "${env_file}" 2>/dev/null || true
}

run_balance_login() {
  [[ -f "${BALANCE_HELPER}" ]] || die "Missing helper: ${BALANCE_HELPER}"
  [[ $# -ge 1 ]] || die "Usage: agent-switch balance-login <provider> [--username USER --prompt-password]"

  local provider="$1"
  shift || true

  local token
  token="$("${PYTHON_BIN}" "${BALANCE_HELPER}" "${provider}" --force-login --emit-token "$@")"
  [[ -n "${token}" ]] || die "empty token returned from provider login"

  local env_key
  env_key="$(token_env_key_for_provider "${provider}")"
  upsert_env_var "${ROOT_ENV_FILE}" "${env_key}" "${token}"

  local masked
  if [[ ${#token} -gt 10 ]]; then
    masked="${token:0:6}...${token: -4}"
  else
    masked="***"
  fi

  echo "Updated ${env_key} in ${ROOT_ENV_FILE} (${masked})"
}

run_claude_switch() {
  "${CLAUDE_GATEWAY_SWITCH}" "$@"
}

run_claude() {
  local cmd="${1:-}"

  if [[ "${PROFILE}" == "native" ]]; then
    case "$cmd" in
      "" )
        exec claude
        ;;
      help|-h|--help)
        usage
        ;;
      status)
        echo "claude backend=native"
        ;;
      env)
        echo "claude backend=native"
        ;;
      *)
        exec claude "$@"
        ;;
    esac
    return 0
  fi

  if [[ "${PROFILE_EXPLICIT}" != "1" ]]; then
    case "$cmd" in
      "")
        exec claude
        ;;
      help|-h|--help)
        usage
        ;;
      list)
        list_profiles
        ;;
      status)
        echo "claude backend=native"
        ;;
      env)
        echo "claude backend=native"
        ;;
      *)
        exec claude "$@"
        ;;
    esac
    return 0
  fi

  case "$cmd" in
    help|-h|--help)
      usage
      ;;
    list)
      list_profiles
      ;;
    backend)
      shift
      require_explicit_profile "claude backend"
      if [[ "${PROFILE}" != "sub2api" ]]; then
        die "backend only applies to profile: sub2api"
      fi
      run_backend "${@:-status}"
      ;;
    serve)
      shift
      require_explicit_profile "claude serve"
      ensure_backend_started
      run_claude_switch serve "${PROFILE}" --port "${PORT}" "$@"
      ;;
    stop)
      shift
      require_explicit_profile "claude stop"
      run_claude_switch stop "${PROFILE}" --port "${PORT}" "$@" || true
      stop_backend_if_needed
      ;;
    status)
      shift
      require_explicit_profile "claude status"
      if [[ "${PROFILE}" == "sub2api" && -x "${SUB2API_CTL}" ]]; then
        run_backend status || true
      fi
      run_claude_switch status "$@"
      ;;
    logs)
      shift
      require_explicit_profile "claude logs"
      mkdir -p "${GATEWAY_DIR}/runtime"
      local log_path="${GATEWAY_DIR}/runtime/litellm-${PROFILE}-${PORT}.log"
      touch "${log_path}"
      chmod 600 "${log_path}" 2>/dev/null || true
      exec tail -f "${log_path}"
      ;;
    env)
      shift
      require_explicit_profile "claude env"
      run_claude_switch env "${PROFILE}" --port "${PORT}" "$@"
      ;;
    prepare)
      shift
      require_explicit_profile "claude prepare"
      ensure_backend_started
      run_claude_switch prepare "${PROFILE}" --port "${PORT}" "$@"
      ;;
    "")
      ensure_backend_started
      run_claude_switch serve "${PROFILE}" --port "${PORT}" >/dev/null
      exec "${CLAUDE_GATEWAY_SWITCH}" claude "${PROFILE}" --port "${PORT}"
      ;;
    *)
      ensure_backend_started
      run_claude_switch serve "${PROFILE}" --port "${PORT}" >/dev/null
      exec "${CLAUDE_GATEWAY_SWITCH}" claude "${PROFILE}" --port "${PORT}" -- "$@"
      ;;
  esac
}

run_codex() {
  local cmd="${1:-}"

  if [[ "${PROFILE}" == "native" ]]; then
    case "$cmd" in
      "")
        exec codex
        ;;
      help|-h|--help)
        usage
        ;;
      status)
        echo "codex backend=native"
        ;;
      env)
        echo "codex backend=native"
        ;;
      export-auth)
        shift
        export_codex_native_auth "${1:-}"
        ;;
      restore-auth)
        shift
        restore_codex_native_auth "${1:-}"
        ;;
      *)
        exec codex "$@"
        ;;
    esac
    return 0
  fi

  case "$cmd" in
    help|-h|--help)
      usage
      ;;
    list)
      list_profiles
      ;;
    use|"")
      shift || true
      if [[ "${cmd}" == "" && "${PROFILE_EXPLICIT}" != "1" ]]; then
        exec codex "$@"
      fi
      require_explicit_profile "codex use"
      persist_codex_profile
      ;;
    backend)
      shift
      require_explicit_profile "codex backend"
      if [[ "${PROFILE}" != "sub2api" ]]; then
        die "backend only applies to profile: sub2api"
      fi
      run_backend "${@:-status}"
      ;;
    serve)
      shift
      require_explicit_profile "codex serve"
      ensure_backend_started
      echo "codex profile ${PROFILE} is ready"
      ;;
    stop)
      shift
      require_explicit_profile "codex stop"
      stop_backend_if_needed
      echo "codex profile ${PROFILE} stopped"
      ;;
    status)
      shift
      require_explicit_profile "codex status"
      load_profile_vars
      if [[ "${PROFILE}" == "sub2api" && -x "${SUB2API_CTL}" ]]; then
        run_backend status || true
      fi
      echo "codex profile=${PROFILE} base_url=${PROFILE_BASE_URL}"
      ;;
    logs)
      shift
      require_explicit_profile "codex logs"
      if [[ "${PROFILE}" != "sub2api" ]]; then
        die "logs only applies to profile: sub2api"
      fi
      run_backend logs
      ;;
    env)
      shift
      require_explicit_profile "codex env"
      load_profile_vars
      echo "PROFILE=${PROFILE}"
      echo "BASE_URL=${PROFILE_BASE_URL}"
      echo "MODEL=${PROFILE_MODEL}"
      echo "ENV_KEY=${PROFILE_ENV_KEY}"
      ;;
    persist)
      shift
      require_explicit_profile "codex persist"
      persist_codex_profile
      ;;
    show|prepare)
      shift
      require_explicit_profile "codex show"
      load_profile_vars
      cat <<JSON
{
  "profile": "${PROFILE}",
  "base_url": "${PROFILE_BASE_URL}",
  "model": "${PROFILE_MODEL}",
  "env_key": "${PROFILE_ENV_KEY}"
}
JSON
      ;;
    run)
      shift
      require_explicit_profile "codex run"
      ensure_backend_started
      load_profile_vars

      local jq_profile
      local jq_model
      local jq_reasoning
      local jq_provider_name
      local jq_base_url
      local jq_wire_api
      local jq_env_key
      local jq_requires_auth
      jq_profile="$(json_quote "${PROFILE}")"
      jq_model="$(json_quote "${PROFILE_MODEL}")"
      jq_reasoning="$(json_quote "${PROFILE_REASONING}")"
      jq_provider_name="$(json_quote "${PROFILE_PROVIDER_NAME}")"
      jq_base_url="$(json_quote "${PROFILE_BASE_URL}")"
      jq_wire_api="$(json_quote "${PROFILE_WIRE_API}")"
      jq_env_key="$(json_quote "${PROFILE_ENV_KEY}")"
      jq_requires_auth="${PROFILE_REQUIRES_OPENAI_AUTH}"

      local -a codex_args
      codex_args=(
        -c 'mcp_servers={}'
        -c "model_provider=${jq_profile}"
        -c "model_providers.${PROFILE}.name=${jq_provider_name}"
        -c "model_providers.${PROFILE}.base_url=${jq_base_url}"
        -c "model_providers.${PROFILE}.wire_api=${jq_wire_api}"
        -c "model_providers.${PROFILE}.requires_openai_auth=${jq_requires_auth}"
        -c "model_providers.${PROFILE}.env_key=${jq_env_key}"
        -c "model=${jq_model}"
      )

      if [[ -n "${PROFILE_REASONING}" ]]; then
        codex_args+=( -c "model_reasoning_effort=${jq_reasoning}" )
      fi

      if [[ -n "${PROFILE_API_KEY}" ]]; then
        export OPENAI_API_KEY="${PROFILE_API_KEY}"
      fi

      exec codex "${codex_args[@]}" "$@"
      ;;
    logout)
      shift
      logout_codex "$@"
      ;;
    *)
      if [[ "${PROFILE_EXPLICIT}" != "1" ]]; then
        exec codex "$cmd" "$@"
      fi
      ensure_backend_started
      load_profile_vars

      local jq_profile
      local jq_model
      local jq_reasoning
      local jq_provider_name
      local jq_base_url
      local jq_wire_api
      local jq_env_key
      local jq_requires_auth
      jq_profile="$(json_quote "${PROFILE}")"
      jq_model="$(json_quote "${PROFILE_MODEL}")"
      jq_reasoning="$(json_quote "${PROFILE_REASONING}")"
      jq_provider_name="$(json_quote "${PROFILE_PROVIDER_NAME}")"
      jq_base_url="$(json_quote "${PROFILE_BASE_URL}")"
      jq_wire_api="$(json_quote "${PROFILE_WIRE_API}")"
      jq_env_key="$(json_quote "${PROFILE_ENV_KEY}")"
      jq_requires_auth="${PROFILE_REQUIRES_OPENAI_AUTH}"

      local -a codex_args
      codex_args=(
        -c 'mcp_servers={}'
        -c "model_provider=${jq_profile}"
        -c "model_providers.${PROFILE}.name=${jq_provider_name}"
        -c "model_providers.${PROFILE}.base_url=${jq_base_url}"
        -c "model_providers.${PROFILE}.wire_api=${jq_wire_api}"
        -c "model_providers.${PROFILE}.requires_openai_auth=${jq_requires_auth}"
        -c "model_providers.${PROFILE}.env_key=${jq_env_key}"
        -c "model=${jq_model}"
      )

      if [[ -n "${PROFILE_REASONING}" ]]; then
        codex_args+=( -c "model_reasoning_effort=${jq_reasoning}" )
      fi

      if [[ -n "${PROFILE_API_KEY}" ]]; then
        export OPENAI_API_KEY="${PROFILE_API_KEY}"
      fi

      exec codex "${codex_args[@]}" "$@"
      ;;
  esac
}

ENTRY_NAME="$(basename "$0")"
INITIAL_ARGC="$#"
CLIENT="claude"

if [[ "$ENTRY_NAME" == "codex-switch" ]]; then
  CLIENT="codex"
elif [[ "$ENTRY_NAME" == "agent-switch" ]]; then
  CLIENT="claude"
fi

if [[ $# -gt 0 ]] && is_client "$1"; then
  CLIENT="$1"
  shift
fi

if [[ "${ENTRY_NAME}" == "agent-switch" && "${INITIAL_ARGC}" -eq 0 && -t 0 && -t 1 && "${AGENT_SWITCH_INTERACTIVE_MENU:-1}" != "0" ]]; then
  run_interactive_menu
  exit 0
fi

if [[ $# -gt 0 ]] && [[ "$1" == "list" ]]; then
  list_profiles
  exit 0
fi

if [[ $# -gt 0 ]] && [[ "$1" == "balance" || "$1" == "quota" ]]; then
  shift
  run_balance "$@"
fi

if [[ $# -gt 0 ]] && [[ "$1" == "balance-login" || "$1" == "quota-login" ]]; then
  shift
  run_balance_login "$@"
  exit 0
fi

if [[ $# -gt 0 ]] && [[ "$1" == "profile" ]]; then
  shift
  run_profile "${1:-}" "${@:2}"
  exit 0
fi

if [[ $# -gt 0 ]] && [[ "$1" != -* ]] && ! is_profile "$1"; then
  if [[ "${CLIENT}" == "codex" ]]; then
    is_codex_command "$1" || die "unknown profile or codex subcommand: $1"
  else
    is_claude_command "$1" || die "unknown profile or claude subcommand: $1"
  fi
fi

PROFILE=""
PROFILE_EXPLICIT=0
if [[ $# -gt 0 ]] && is_profile "$1"; then
  PROFILE="$1"
  PROFILE_EXPLICIT=1
  shift
fi
if [[ -z "${PROFILE}" ]]; then
  PROFILE="$(default_profile)"
fi
PORT="$(port_for_profile "$PROFILE")"

if [[ "$CLIENT" == "claude" ]]; then
  run_claude "${@:-}"
else
  run_codex "${@:-}"
fi
