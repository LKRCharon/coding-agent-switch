#!/usr/bin/env bash

set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
BIN_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
PROJECT_ROOT="$(cd "${BIN_DIR}/.." && pwd)"
GATEWAY_DIR="${PROJECT_ROOT}/gateway"
CLAUDE_GATEWAY_SWITCH="${GATEWAY_DIR}/claude-gateway-switch"
PROFILES_ROOT="${PROJECT_ROOT}/profiles"
PROFILES_LOCAL_ROOT="${PROFILES_LOCAL_ROOT:-${PROJECT_ROOT}/profiles-local}"
BALANCE_HELPER="${PROJECT_ROOT}/lib/provider_balance.py"
ROOT_ENV_FILE="${ROOT_ENV_FILE:-${PROJECT_ROOT}/.env}"
SUB2API_CTL="${SUB2API_CTL:-${PROJECT_ROOT}/sub2api-local/sub2api-localctl}"
LOCAL_NO_PROXY="127.0.0.1,localhost"
PYTHON_BIN="${GATEWAY_DIR}/.venv/bin/python"
if [[ ! -x "${PYTHON_BIN}" ]]; then
  PYTHON_BIN="python3"
fi

export NO_PROXY="$LOCAL_NO_PROXY${NO_PROXY:+,$NO_PROXY}"
export no_proxy="$LOCAL_NO_PROXY${no_proxy:+,$no_proxy}"

load_local_env_file() {
  local env_file="$1"
  [[ -f "${env_file}" ]] || return 0
  set -a
  # shellcheck disable=SC1090
  source "${env_file}"
  set +a
}

load_local_env_file "${ROOT_ENV_FILE}"

usage() {
  cat <<'USAGE'
Usage:
  agent-switch [claude|codex] [profile] [serve|stop|status|logs|env|prepare|backend] [extra args...]
  agent-switch codex [profile] persist
  agent-switch [claude|codex] [profile] [client args...]
  agent-switch balance <provider> [--token TOKEN | --username USER --prompt-password] [--days 30] [--json]
  agent-switch balance-login <provider> [--username USER --prompt-password]
  agent-switch profile list
  agent-switch profile create <name> --base-url URL [--env-key KEY] [--model MODEL] [--reasoning LEVEL]
  agent-switch list

Profiles:
  native   -> claude/codex native mode (no gateway)
  provider -> default port 4030 (generic provider endpoint)
  local profiles can be stored under profiles-local/ (ignored by git)

Examples:
  ./bin/agent-switch list
  ./bin/agent-switch codex provider exec "Reply with exactly OK."
  ./bin/agent-switch codex ttapi persist
  ./bin/agent-switch claude native
  ./bin/agent-switch claude provider -p "Reply with exactly OK."
  ./bin/agent-switch profile create ttapi --base-url https://api.example.com/v1 --env-key TTAPI_API_KEY
  ./bin/agent-switch balance provider --json
  ./bin/agent-switch balance-login provider --username your_name --prompt-password
USAGE
}

die() {
  echo "$*" >&2
  exit 1
}

is_client() {
  case "$1" in
    claude|codex) return 0 ;;
    *) return 1 ;;
  esac
}

is_profile() {
  [[ "$1" == "native" ]] && return 0
  [[ -n "$(resolve_profile_dir "$1")" ]]
}

resolve_profile_dir() {
  local profile="$1"
  if [[ -d "${PROFILES_LOCAL_ROOT}/${profile}" ]]; then
    echo "${PROFILES_LOCAL_ROOT}/${profile}"
    return 0
  fi
  if [[ -d "${PROFILES_ROOT}/${profile}" ]]; then
    echo "${PROFILES_ROOT}/${profile}"
    return 0
  fi
  return 1
}

list_profiles() {
  echo "native"
  {
    if [[ -d "${PROFILES_ROOT}" ]]; then
      find "${PROFILES_ROOT}" -mindepth 1 -maxdepth 1 -type d -exec basename {} \;
    fi
    if [[ -d "${PROFILES_LOCAL_ROOT}" ]]; then
      find "${PROFILES_LOCAL_ROOT}" -mindepth 1 -maxdepth 1 -type d -exec basename {} \;
    fi
  } | sort -u
}

default_profile() {
  local first
  first="$({
    if [[ -d "${PROFILES_ROOT}" ]]; then
      find "${PROFILES_ROOT}" -mindepth 1 -maxdepth 1 -type d -exec basename {} \;
    fi
    if [[ -d "${PROFILES_LOCAL_ROOT}" ]]; then
      find "${PROFILES_LOCAL_ROOT}" -mindepth 1 -maxdepth 1 -type d -exec basename {} \;
    fi
  } | sort -u | head -n 1)"
  if [[ -n "${first}" ]]; then
    echo "${first}"
    return
  fi

  echo "native"
}

port_for_profile() {
  case "$1" in
    provider) echo "4030" ;;
    *) echo "4040" ;;
  esac
}

run_backend() {
  [[ -x "${SUB2API_CTL}" ]] || die "sub2api backend controller not found: ${SUB2API_CTL}"
  "${SUB2API_CTL}" "$@"
}

ensure_backend_started() {
  if [[ "${PROFILE}" == "sub2api" ]]; then
    run_backend start
  fi
}

stop_backend_if_needed() {
  if [[ "${PROFILE}" == "sub2api" ]]; then
    run_backend stop
  fi
}

json_quote() {
  "${PYTHON_BIN}" -c 'import json,sys; print(json.dumps(sys.argv[1], ensure_ascii=True))' "$1"
}

load_profile_vars() {
  local profile_dir
  profile_dir="$(resolve_profile_dir "${PROFILE}")" || die "unknown profile: ${PROFILE}"

  eval "$("${PYTHON_BIN}" - "$profile_dir" "$PROFILE" <<'PY'
import json
import os
import shlex
import sys
try:
    import tomllib
except ModuleNotFoundError:
    import tomli as tomllib
from pathlib import Path

profile_dir = Path(sys.argv[1])
profile = sys.argv[2]
cfg_path = profile_dir / "config.toml"
auth_path = profile_dir / "auth.json"

if not cfg_path.is_file():
    raise SystemExit(f"missing profile config: {cfg_path}")

cfg = tomllib.loads(cfg_path.read_text(encoding="utf-8"))
providers = cfg.get("model_providers", {})
provider = providers.get(profile)
if provider is None:
    raise SystemExit(f"profile provider section missing: model_providers.{profile}")

auth = {}
if auth_path.is_file():
    auth = json.loads(auth_path.read_text(encoding="utf-8"))

env_key = str(provider.get("env_key", "OPENAI_API_KEY"))
api_key = str(auth.get("OPENAI_API_KEY", "")).strip() or str(os.getenv(env_key, "")).strip() or str(os.getenv("OPENAI_API_KEY", "")).strip()

model = str(cfg.get("model", "gpt-5.4"))
reasoning = str(cfg.get("model_reasoning_effort", ""))
base_url = str(provider.get("base_url", ""))
provider_name = str(provider.get("name", profile))
wire_api = str(provider.get("wire_api", "responses"))
requires_auth = bool(provider.get("requires_openai_auth", True))


def emit(k: str, v: str) -> None:
    print(f"{k}={shlex.quote(v)}")

emit("PROFILE_MODEL", model)
emit("PROFILE_REASONING", reasoning)
emit("PROFILE_API_KEY", api_key)
emit("PROFILE_BASE_URL", base_url)
emit("PROFILE_PROVIDER_NAME", provider_name)
emit("PROFILE_WIRE_API", wire_api)
emit("PROFILE_ENV_KEY", env_key)
emit("PROFILE_REQUIRES_OPENAI_AUTH", "true" if requires_auth else "false")
PY
)"
}

persist_codex_profile() {
  [[ "${PROFILE}" != "native" ]] || die "persist does not apply to native"
  load_profile_vars
  [[ -n "${PROFILE_API_KEY}" ]] || die "No API key found for ${PROFILE}. Put it in ${ROOT_ENV_FILE} (key: ${PROFILE_ENV_KEY}) or profiles-local/${PROFILE}/auth.json"

  local codex_home
  local config_path
  local auth_path
  codex_home="${CODEX_HOME:-${HOME}/.codex}"
  config_path="${codex_home}/config.toml"
  auth_path="${codex_home}/auth.json"

  "${PYTHON_BIN}" - "$config_path" "$auth_path" "$PROFILE" "$PROFILE_MODEL" "$PROFILE_REASONING" "$PROFILE_PROVIDER_NAME" "$PROFILE_BASE_URL" "$PROFILE_WIRE_API" "$PROFILE_REQUIRES_OPENAI_AUTH" "$PROFILE_API_KEY" <<'PY'
from __future__ import annotations
import json
import shutil
import sys
from datetime import datetime
from pathlib import Path
import toml

config_path = Path(sys.argv[1])
auth_path = Path(sys.argv[2])
profile = sys.argv[3]
model = sys.argv[4]
reasoning = sys.argv[5]
provider_name = sys.argv[6]
base_url = sys.argv[7]
wire_api = sys.argv[8]
requires_auth = sys.argv[9].lower() == "true"
api_key = sys.argv[10]

config_path.parent.mkdir(parents=True, exist_ok=True)
auth_path.parent.mkdir(parents=True, exist_ok=True)

ts = datetime.now().strftime("%Y%m%d-%H%M%S")

cfg: dict = {}
if config_path.exists() and config_path.stat().st_size > 0:
    cfg = toml.load(config_path)
    shutil.copy2(config_path, config_path.with_name(f"{config_path.name}.bak.{ts}"))

providers = cfg.get("model_providers")
if not isinstance(providers, dict):
    providers = {}
providers["agent_switch"] = {
    "name": provider_name or profile,
    "base_url": base_url,
    "wire_api": wire_api or "responses",
    "requires_openai_auth": requires_auth,
    "env_key": "OPENAI_API_KEY",
}
cfg["model_provider"] = "agent_switch"
cfg["model_providers"] = providers
if model:
    cfg["model"] = model
if reasoning:
    cfg["model_reasoning_effort"] = reasoning

config_path.write_text(toml.dumps(cfg), encoding="utf-8")

auth: dict = {}
if auth_path.exists() and auth_path.stat().st_size > 0:
    auth = json.loads(auth_path.read_text(encoding="utf-8"))
    shutil.copy2(auth_path, auth_path.with_name(f"{auth_path.name}.bak.{ts}"))
auth["OPENAI_API_KEY"] = api_key
auth_path.write_text(json.dumps(auth, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY

  echo "Persisted codex profile=${PROFILE} to ${config_path} (provider key: agent_switch)"
  echo "Updated ${auth_path} OPENAI_API_KEY to active profile key"
}

run_profile() {
  local sub="${1:-}"
  case "$sub" in
    ""|help|-h|--help)
      cat <<'USAGE'
Usage:
  agent-switch profile list
  agent-switch profile create <name> --base-url URL [--env-key KEY] [--model MODEL] [--reasoning LEVEL]
USAGE
      ;;
    list)
      list_profiles
      ;;
    create)
      shift || true
      local name="${1:-}"
      [[ -n "${name}" ]] || die "Usage: agent-switch profile create <name> --base-url URL [--env-key KEY] [--model MODEL] [--reasoning LEVEL]"
      shift || true
      [[ "${name}" =~ ^[a-z0-9][a-z0-9-]*$ ]] || die "profile name must match: [a-z0-9][a-z0-9-]*"

      local base_url=""
      local env_key=""
      local model="gpt-5.4"
      local reasoning="high"
      local wire_api="responses"

      while [[ $# -gt 0 ]]; do
        case "$1" in
          --base-url)
            base_url="${2:-}"
            shift 2
            ;;
          --env-key)
            env_key="${2:-}"
            shift 2
            ;;
          --model)
            model="${2:-}"
            shift 2
            ;;
          --reasoning)
            reasoning="${2:-}"
            shift 2
            ;;
          --wire-api)
            wire_api="${2:-}"
            shift 2
            ;;
          *)
            die "unknown option: $1"
            ;;
        esac
      done

      [[ -n "${base_url}" ]] || die "--base-url is required"
      if [[ -z "${env_key}" ]]; then
        env_key="$(echo "${name}" | tr '[:lower:]-' '[:upper:]_')_API_KEY"
      fi

      local profile_dir="${PROFILES_LOCAL_ROOT}/${name}"
      mkdir -p "${profile_dir}"
      cat > "${profile_dir}/config.toml" <<EOF
# local profile: ${name}
model_provider = "${name}"
model = "${model}"
model_reasoning_effort = "${reasoning}"

[model_providers.${name}]
name = "${name}"
base_url = "${base_url}"
wire_api = "${wire_api}"
requires_openai_auth = true
env_key = "${env_key}"

[features]
multi_agent = true
EOF

      if [[ ! -f "${profile_dir}/auth.json.template" ]]; then
        cat > "${profile_dir}/auth.json.template" <<'EOF'
{
  "OPENAI_API_KEY": "your_api_key_here"
}
EOF
      fi
      echo "Created local profile: ${name}"
      echo "Path: ${profile_dir}"
      echo "Set key in ${ROOT_ENV_FILE}: ${env_key}=..."
      ;;
    *)
      die "unknown profile subcommand: ${sub}"
      ;;
  esac
}

run_balance() {
  [[ -f "${BALANCE_HELPER}" ]] || die "Missing helper: ${BALANCE_HELPER}"
  exec "${PYTHON_BIN}" "${BALANCE_HELPER}" "$@"
}

token_env_key_for_provider() {
  case "$1" in
    provider) echo "PROVIDER_AUTH_TOKEN" ;;
    *) echo "${1^^}_AUTH_TOKEN" ;;
  esac
}

upsert_env_var() {
  local env_file="$1"
  local key="$2"
  local value="$3"
  "${PYTHON_BIN}" - "$env_file" "$key" "$value" <<'PY'
from pathlib import Path
import sys

env_path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]

line = f"{key}='{value.replace("'", "'\"'\"'")}'"

lines = []
if env_path.exists():
    lines = env_path.read_text(encoding="utf-8").splitlines()

updated = False
new_lines = []
for raw in lines:
    stripped = raw.strip()
    if stripped.startswith(f"{key}="):
        if not updated:
            new_lines.append(line)
            updated = True
        continue
    new_lines.append(raw)

if not updated:
    if new_lines and new_lines[-1] != "":
        new_lines.append("")
    new_lines.append(line)

env_path.write_text("\n".join(new_lines) + "\n", encoding="utf-8")
PY
  chmod 600 "${env_file}" 2>/dev/null || true
}

run_balance_login() {
  [[ -f "${BALANCE_HELPER}" ]] || die "Missing helper: ${BALANCE_HELPER}"
  [[ $# -ge 1 ]] || die "Usage: agent-switch balance-login <provider> [--username USER --prompt-password]"

  local provider="$1"
  shift || true

  local token
  token="$("${PYTHON_BIN}" "${BALANCE_HELPER}" "${provider}" --force-login --emit-token "$@")"
  [[ -n "${token}" ]] || die "empty token returned from provider login"

  local env_key
  env_key="$(token_env_key_for_provider "${provider}")"
  upsert_env_var "${ROOT_ENV_FILE}" "${env_key}" "${token}"

  local masked
  if [[ ${#token} -gt 10 ]]; then
    masked="${token:0:6}...${token: -4}"
  else
    masked="***"
  fi

  echo "Updated ${env_key} in ${ROOT_ENV_FILE} (${masked})"
}

run_claude_switch() {
  "${CLAUDE_GATEWAY_SWITCH}" "$@"
}

run_claude() {
  local cmd="${1:-}"

  if [[ "${PROFILE}" == "native" ]]; then
    case "$cmd" in
      "" )
        exec claude
        ;;
      help|-h|--help)
        usage
        ;;
      status)
        echo "claude backend=native"
        ;;
      env)
        echo "claude backend=native"
        ;;
      *)
        exec claude "$@"
        ;;
    esac
    return 0
  fi

  case "$cmd" in
    help|-h|--help)
      usage
      ;;
    list)
      list_profiles
      ;;
    backend)
      shift
      if [[ "${PROFILE}" != "sub2api" ]]; then
        die "backend only applies to profile: sub2api"
      fi
      run_backend "${@:-status}"
      ;;
    serve)
      shift
      ensure_backend_started
      run_claude_switch serve "${PROFILE}" --port "${PORT}" "$@"
      ;;
    stop)
      shift
      run_claude_switch stop "${PROFILE}" --port "${PORT}" "$@" || true
      stop_backend_if_needed
      ;;
    status)
      shift
      if [[ "${PROFILE}" == "sub2api" && -x "${SUB2API_CTL}" ]]; then
        run_backend status || true
      fi
      run_claude_switch status "$@"
      ;;
    logs)
      shift
      mkdir -p "${GATEWAY_DIR}/runtime"
      local log_path="${GATEWAY_DIR}/runtime/litellm-${PROFILE}-${PORT}.log"
      touch "${log_path}"
      chmod 600 "${log_path}" 2>/dev/null || true
      exec tail -f "${log_path}"
      ;;
    env)
      shift
      run_claude_switch env "${PROFILE}" --port "${PORT}" "$@"
      ;;
    prepare)
      shift
      ensure_backend_started
      run_claude_switch prepare "${PROFILE}" --port "${PORT}" "$@"
      ;;
    "")
      ensure_backend_started
      run_claude_switch serve "${PROFILE}" --port "${PORT}" >/dev/null
      exec "${CLAUDE_GATEWAY_SWITCH}" claude "${PROFILE}" --port "${PORT}"
      ;;
    *)
      ensure_backend_started
      run_claude_switch serve "${PROFILE}" --port "${PORT}" >/dev/null
      exec "${CLAUDE_GATEWAY_SWITCH}" claude "${PROFILE}" --port "${PORT}" -- "$@"
      ;;
  esac
}

run_codex() {
  local cmd="${1:-}"

  if [[ "${PROFILE}" == "native" ]]; then
    case "$cmd" in
      "")
        exec codex
        ;;
      help|-h|--help)
        usage
        ;;
      status)
        echo "codex backend=native"
        ;;
      env)
        echo "codex backend=native"
        ;;
      *)
        exec codex "$@"
        ;;
    esac
    return 0
  fi

  case "$cmd" in
    help|-h|--help)
      usage
      ;;
    list)
      list_profiles
      ;;
    backend)
      shift
      if [[ "${PROFILE}" != "sub2api" ]]; then
        die "backend only applies to profile: sub2api"
      fi
      run_backend "${@:-status}"
      ;;
    serve)
      shift
      ensure_backend_started
      echo "codex profile ${PROFILE} is ready"
      ;;
    stop)
      shift
      stop_backend_if_needed
      echo "codex profile ${PROFILE} stopped"
      ;;
    status)
      shift
      load_profile_vars
      if [[ "${PROFILE}" == "sub2api" && -x "${SUB2API_CTL}" ]]; then
        run_backend status || true
      fi
      echo "codex profile=${PROFILE} base_url=${PROFILE_BASE_URL}"
      ;;
    logs)
      shift
      if [[ "${PROFILE}" != "sub2api" ]]; then
        die "logs only applies to profile: sub2api"
      fi
      run_backend logs
      ;;
    env)
      shift
      load_profile_vars
      echo "PROFILE=${PROFILE}"
      echo "BASE_URL=${PROFILE_BASE_URL}"
      echo "MODEL=${PROFILE_MODEL}"
      echo "ENV_KEY=${PROFILE_ENV_KEY}"
      ;;
    persist)
      shift
      persist_codex_profile
      ;;
    prepare)
      shift
      load_profile_vars
      cat <<JSON
{
  "profile": "${PROFILE}",
  "base_url": "${PROFILE_BASE_URL}",
  "model": "${PROFILE_MODEL}",
  "env_key": "${PROFILE_ENV_KEY}"
}
JSON
      ;;
    *)
      ensure_backend_started
      load_profile_vars

      local jq_profile
      local jq_model
      local jq_reasoning
      local jq_provider_name
      local jq_base_url
      local jq_wire_api
      local jq_env_key
      local jq_requires_auth
      jq_profile="$(json_quote "${PROFILE}")"
      jq_model="$(json_quote "${PROFILE_MODEL}")"
      jq_reasoning="$(json_quote "${PROFILE_REASONING}")"
      jq_provider_name="$(json_quote "${PROFILE_PROVIDER_NAME}")"
      jq_base_url="$(json_quote "${PROFILE_BASE_URL}")"
      jq_wire_api="$(json_quote "${PROFILE_WIRE_API}")"
      jq_env_key="$(json_quote "${PROFILE_ENV_KEY}")"
      jq_requires_auth="${PROFILE_REQUIRES_OPENAI_AUTH}"

      local -a codex_args
      codex_args=(
        -c 'mcp_servers={}'
        -c "model_provider=${jq_profile}"
        -c "model_providers.${PROFILE}.name=${jq_provider_name}"
        -c "model_providers.${PROFILE}.base_url=${jq_base_url}"
        -c "model_providers.${PROFILE}.wire_api=${jq_wire_api}"
        -c "model_providers.${PROFILE}.requires_openai_auth=${jq_requires_auth}"
        -c "model_providers.${PROFILE}.env_key=${jq_env_key}"
        -c "model=${jq_model}"
      )

      if [[ -n "${PROFILE_REASONING}" ]]; then
        codex_args+=( -c "model_reasoning_effort=${jq_reasoning}" )
      fi

      if [[ -n "${PROFILE_API_KEY}" ]]; then
        export OPENAI_API_KEY="${PROFILE_API_KEY}"
      fi

      exec codex "${codex_args[@]}" "$@"
      ;;
  esac
}

ENTRY_NAME="$(basename "$0")"
CLIENT="claude"

if [[ "$ENTRY_NAME" == "codex-switch" ]]; then
  CLIENT="codex"
elif [[ "$ENTRY_NAME" == "agent-switch" ]]; then
  CLIENT="claude"
fi

if [[ $# -gt 0 ]] && is_client "$1"; then
  CLIENT="$1"
  shift
fi

if [[ $# -gt 0 ]] && [[ "$1" == "list" ]]; then
  list_profiles
  exit 0
fi

if [[ $# -gt 0 ]] && [[ "$1" == "balance" || "$1" == "quota" ]]; then
  shift
  run_balance "$@"
fi

if [[ $# -gt 0 ]] && [[ "$1" == "balance-login" || "$1" == "quota-login" ]]; then
  shift
  run_balance_login "$@"
  exit 0
fi

if [[ $# -gt 0 ]] && [[ "$1" == "profile" ]]; then
  shift
  run_profile "${1:-}" "${@:2}"
  exit 0
fi

PROFILE=""
if [[ $# -gt 0 ]] && is_profile "$1"; then
  PROFILE="$1"
  shift
fi
if [[ -z "${PROFILE}" ]]; then
  PROFILE="$(default_profile)"
fi
PORT="$(port_for_profile "$PROFILE")"

if [[ "$CLIENT" == "claude" ]]; then
  run_claude "${@:-}"
else
  run_codex "${@:-}"
fi
