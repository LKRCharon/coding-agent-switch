# Copy to .env only if you want env-based fallback keys.
# Prefer profiles-local/<name>/auth.json for primary API keys.
# This file is loaded automatically by bin/agent-switch.

# Provider API keys (optional fallback for Codex direct and Claude-via-LiteLLM)
PROVIDER_API_KEY=
TTAPI_API_KEY=
FOX_API_KEY=

# Optional: dashboard token for `balance provider`
PROVIDER_AUTH_TOKEN=
PROVIDER_USERNAME=
